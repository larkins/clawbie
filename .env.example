# Clawbie Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@127.0.0.1:5432/clawbie

# Individual components (alternative to DATABASE_URL)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DB_NAME=clawbie
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# ============================================================
# LLM SERVICES (Local Ollama)
# ============================================================
# Inference endpoint (Ollama with LLM)
INFERENCE_HOST=http://127.0.0.1:11434
INFERENCE_MODEL=YOUR_MODEL  # e.g. qwen3.5:35b
INFERENCE_TIMEOUT_SECONDS=90

# Embedding endpoint (Ollama with embedding model)
EMBEDDING_HOST=http://127.0.0.1:11436
EMBEDDING_MODEL=YOUR_EMBEDDING_MODEL  # e.g. BAAI/bge-m3
EMBEDDING_BIND_ADDRESS=127.0.0.1

# ============================================================
# MINIMAX TTS (Optional - for voice output)
# ============================================================
# Get API key from https://www.minimaxi.com/
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY

# Path to clawbie source (auto-detected, usually no need to set)
# CLAWBIE_SRC=/path/to/clawbie/src

# Output directory for TTS audio files (default: ~/.openclaw/workspace/)
TTS_OUTPUT_DIR=~/.openclaw/workspace/

# Local TTS proxy URL (OpenAI-compatible, runs on port 18793)
# Start with: python minixtts_proxy/simple_proxy.py
# Or via systemd: systemctl --user start minixtts-proxy
# TTS_PROXY_URL=http://127.0.0.1:18793

# ============================================================
# EMAIL SERVER (Local mail server)
# ============================================================
# Local mail server API base URL
EMAIL_SERVER=http://127.0.0.1:5003

# Email account for sending (must exist on the mail server)
EMAIL_ADDRESS=YOUR_EMAIL@YOUR_DOMAIN
EMAIL_PASSWORD=YOUR_EMAIL_PASSWORD

# Email endpoints (usually don't need to change)
EMAIL_AUTH_ENDPOINT=/auth/login
EMAIL_SEND_ENDPOINT=/api/emails
EMAIL_TIMEOUT_SECONDS=10

# ============================================================
# OPENCLAW BRIDGE (optional - for transcript polling)
# ============================================================
# Glob pattern for OpenClaw session transcripts
# Default: ~/.openclaw/agents/*/sessions/*.jsonl
OPENCLAW_TRANSCRIPT_GLOBS=~/.openclaw/agents/*/sessions/*.jsonl

# Path to OpenClaw sessions index (for sub-agent tracking)
OPENCLAW_SESSIONS_INDEX=~/.openclaw/agents/main/sessions/sessions.json
