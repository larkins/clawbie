# Protophysics Email Skill — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# MAIL SERVER
# ============================================================
# Base URL of the Python/PostgreSQL mail server
# The mail server must be running and reachable at this URL
EMAIL_SERVER=http://127.0.0.1:5003

# Email account for sending and inbox access
EMAIL_ADDRESS=your@yourdomain.com

# Account password
EMAIL_PASSWORD=your_password

# Default recipient for send command (optional — can override with --to)
EMAIL_TO=recipient@example.com
